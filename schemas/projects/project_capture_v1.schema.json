{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project_capture_v1.schema.json",
  "title": "Project Capture",
  "description": "Customer opportunity intake with known/estimated/unknown classification",
  "type": "object",
  "required": [
    "project_name",
    "status",
    "known_facts",
    "estimated_facts",
    "unknown_items",
    "open_questions"
  ],
  "additionalProperties": false,
  "properties": {
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "customer": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "in_review", "approved", "superseded"]
    },
    "description": {
      "type": "string"
    },
    "created_date": {
      "type": "string",
      "format": "date"
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    },
    "known_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "value", "source"],
        "additionalProperties": false,
        "properties": {
          "field": {"type": "string"},
          "value": {},
          "source": {"type": "string"},
          "captured_date": {"type": "string", "format": "date"}
        }
      }
    },
    "estimated_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "value", "source", "confidence"],
        "additionalProperties": false,
        "properties": {
          "field": {"type": "string"},
          "value": {},
          "source": {"type": "string"},
          "confidence": {
            "type": "string",
            "enum": ["draft", "reviewed", "approved"]
          },
          "captured_date": {"type": "string", "format": "date"},
          "captured_by": {"type": "string"}
        }
      }
    },
    "unknown_items": {
      "type": "array",
      "items": {"type": "string"}
    },
    "open_questions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "References to question IDs in open_questions file"
    },
    "artifacts": {
      "type": "array",
      "description": "Design artifacts (CAD files, PDFs, etc.)",
      "items": {
        "type": "object",
        "required": ["type", "status"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["STEP", "STL", "OpenSCAD", "PDF", "DXF", "DWG", "other"]
          },
          "filename": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["exists_locally", "embedded_in_pdf", "received", "pending", "not_available"]
          },
          "location": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
