{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bid_v1.schema.json",
  "title": "BidV1",
  "description": "Internal bid calculation record with cost basis, risk factors, and margin pricing",
  "type": "object",
  "required": [
    "bid_id",
    "project_name",
    "customer_name",
    "revision",
    "status",
    "created_at",
    "updated_at",
    "assumptions",
    "line_items",
    "cost_basis",
    "pricing",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "bid_id": {
      "type": "string",
      "minLength": 1
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "customer_name": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "approved", "sent", "superseded", "rejected"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "project_ref": {
      "type": ["string", "null"]
    },
    "manufacturing_ref": {
      "type": ["string", "null"]
    },
    "scenario_ref": {
      "type": ["string", "null"]
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "value", "source", "confidence"],
        "additionalProperties": false,
        "properties": {
          "field": {"type": "string"},
          "value": {},
          "source": {"type": "string"},
          "confidence": {
            "type": "string",
            "enum": ["draft", "reviewed", "approved", "superseded", "unknown"]
          },
          "note": {"type": "string"}
        }
      }
    },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "category", "quantity", "unit", "unit_cost", "total_cost"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "category": {"type": "string"},
          "quantity": {"type": "number", "minimum": 0},
          "unit": {"type": "string"},
          "unit_cost": {"type": "number", "minimum": 0},
          "total_cost": {"type": "number", "minimum": 0},
          "note": {"type": "string"}
        }
      }
    },
    "cost_basis": {
      "type": "object",
      "required": [
        "direct_material_cost",
        "direct_labor_cost",
        "machine_time_cost",
        "tooling_cost",
        "setup_cost",
        "finishing_cost",
        "finishing_material_cost",
        "engineering_cost",
        "base_manufacturing_cost"
      ],
      "additionalProperties": false,
      "properties": {
        "direct_material_cost": {"type": "number", "minimum": 0},
        "direct_labor_cost": {"type": "number", "minimum": 0},
        "machine_time_cost": {"type": "number", "minimum": 0},
        "tooling_cost": {"type": "number", "minimum": 0},
        "setup_cost": {"type": "number", "minimum": 0},
        "finishing_cost": {"type": "number", "minimum": 0},
        "finishing_material_cost": {"type": "number", "minimum": 0},
        "engineering_cost": {"type": "number", "minimum": 0},
        "base_manufacturing_cost": {"type": "number", "minimum": 0}
      }
    },
    "pricing": {
      "type": "object",
      "required": [
        "tool_wear_pct",
        "manufacturing_contingency_pct",
        "business_overhead_pct",
        "engineering_recovery_pct",
        "target_margin_pct",
        "risked_cost",
        "quote_price",
        "quantity",
        "price_per_unit"
      ],
      "additionalProperties": false,
      "properties": {
        "tool_wear_pct": {"type": "number", "minimum": 0},
        "manufacturing_contingency_pct": {"type": "number", "minimum": 0},
        "business_overhead_pct": {"type": "number", "minimum": 0},
        "engineering_recovery_pct": {"type": "number", "minimum": 0},
        "target_margin_pct": {"type": "number", "minimum": 0, "exclusiveMaximum": 100},
        "risked_cost": {"type": "number", "minimum": 0},
        "quote_price": {"type": "number", "minimum": 0},
        "quantity": {"type": "integer", "minimum": 1},
        "price_per_unit": {"type": "number", "minimum": 0}
      }
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
